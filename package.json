{
  "name": "reservation-mvp",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.15.0",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "dev": "pnpm --filter @reservation/web dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm --recursive test",
    "e2e": "pnpm --filter @reservation/web e2e",
    "generate:api-client": "openapi-typescript specs/api/openapi.yaml -o packages/api-client/src/schema.d.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "openapi-typescript": "7.13.0",
    "oxlint": "1.60.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
